{
  "_schema": "DonatoSkills Project Registry v1",
  "_docs": "shared-references/project-registry.md",
  "_note": "Replace the example-project below with your own. See setup/SKILL.md for guided onboarding.",

  "projects": {
    "example-project": {
      "name": "Example Project",
      "description": "Replace with your project description",
      "specs_path": null,
      "brand_brief": null,
      "buffer": {
        "api_key_env": "BUFFER_API_KEY",
        "organization_id": null,
        "channels": {
          "twitter": {
            "id": "YOUR_BUFFER_CHANNEL_ID",
            "name": "your-handle",
            "username": "@yourhandle"
          }
        }
      },
      "late": {
        "api_key_env": "LATE_API_KEY",
        "profile_id": "YOUR_LATE_PROFILE_ID",
        "accounts": {
          "tiktok": {
            "id": "YOUR_LATE_ACCOUNT_ID",
            "name": "Your Account Name",
            "username": "@yourhandle"
          }
        }
      },
      "cloudinary": {
        "cloud_name_env": "CLOUDINARY_CLOUD_NAME",
        "api_key_env": "CLOUDINARY_API_KEY",
        "api_secret_env": "CLOUDINARY_API_SECRET"
      },
      "tts": {
        "providers": ["grok", "gemini", "elevenlabs"],
        "default_provider": "grok",
        "grok": {
          "api_key_env": "GROK_API_KEY",
          "default_voice": "onyx"
        },
        "gemini": {
          "api_key_env": "GEMINI_API_KEY",
          "default_voice": "Kore"
        },
        "elevenlabs": {
          "api_key_env": "ELEVENLABS_API_KEY",
          "default_voice": "Adam"
        }
      },
      "image_gen": {
        "providers": ["gemini", "openai"],
        "default_provider": "gemini",
        "gemini": {
          "api_key_env": "GEMINI_API_KEY",
          "default_model": "gemini-2.5-flash-image"
        },
        "openai": {
          "api_key_env": "OPENAI_API_KEY",
          "default_model": "gpt-image-1"
        }
      },
      "analytics_loop": {
        "collection_window_hours": 48,
        "min_impressions": 500,
        "exploit_explore_ratio": [2, 1],
        "scoring_weights": {
          "shares": 4,
          "saves": 3,
          "comments": 2,
          "likes": 1
        },
        "template_promotion": {
          "min_lift": 0.15,
          "min_channels": 3,
          "min_cycles": 2,
          "min_sample": 10
        }
      },
      "defaults": {
        "tone": "casual, confident",
        "content_pillars": ["product", "education", "personality", "social-proof"],
        "posting_frequency": {
          "twitter": "daily"
        }
      },
      "created": "2026-03-16",
      "updated": "2026-03-16"
    }
  },

  "default_project": "example-project"
}
